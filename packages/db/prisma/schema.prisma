generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  createdAt      DateTime        @default(now())
  accounts       Account[]
  sessions       Session[]
  portfolios     Portfolio[]
  decisionAudits DecisionAudit[]
  backtestRuns   BacktestRun[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Portfolio {
  id             String          @id @default(cuid())
  userId         String
  name           String
  balance        Decimal
  createdAt      DateTime        @default(now())
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades         Trade[]
  decisionAudits DecisionAudit[]
  backtestRuns   BacktestRun[]
  strategies     PortfolioStrategy[]
}

model Trade {
  id          String    @id @default(cuid())
  portfolioId String
  symbol      String
  side        String
  quantity    Decimal
  entryPrice  Decimal
  exitPrice   Decimal?
  pnl         Decimal?
  strategy    String
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

model DecisionAudit {
  id                 String    @id @default(cuid())
  userId             String?
  portfolioId        String?
  symbol             String
  agent              String
  regime             String
  strategy           String
  signal             String
  confidence         Float
  riskScore          Float
  suggestedSize      Decimal
  stopLossPct        Float
  riskApproved       Boolean
  refused            Boolean
  riskReasons        Json
  rationale          String
  decisionJson       Json
  createdAt          DateTime  @default(now())
  user               User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  portfolio          Portfolio? @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
}

model BacktestRun {
  id            String             @id @default(cuid())
  userId        String?
  portfolioId   String?
  symbol        String
  strategy      String
  initialBalance Decimal
  totalReturn   Float
  maxDrawdown   Float
  sharpeRatio   Float
  winRate       Float
  tradeCount    Int
  createdAt     DateTime           @default(now())
  user          User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  portfolio     Portfolio?         @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
  equityCurve   BacktestEquityPoint[]
  trades        BacktestTrade[]
}

model BacktestEquityPoint {
  id          String      @id @default(cuid())
  backtestId  String
  timestamp   DateTime
  equity      Decimal
  backtest    BacktestRun @relation(fields: [backtestId], references: [id], onDelete: Cascade)

  @@index([backtestId, timestamp])
}

model BacktestTrade {
  id          String      @id @default(cuid())
  backtestId  String
  symbol      String
  side        String
  quantity    Decimal
  entryPrice  Decimal
  exitPrice   Decimal?
  pnl         Decimal?
  openedAt    DateTime
  closedAt    DateTime?
  strategy    String
  backtest    BacktestRun @relation(fields: [backtestId], references: [id], onDelete: Cascade)
}

model StrategyCatalogEntry {
  id             String              @id
  name           String
  version        String
  description    String
  author         String
  riskDisclosure String
  tags           Json
  parameters     Json
  source         String
  status         String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  activations    PortfolioStrategy[]
}

model PortfolioStrategy {
  id          String               @id @default(cuid())
  portfolioId String
  strategyId  String
  enabled     Boolean              @default(false)
  parameters  Json
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  portfolio   Portfolio            @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  strategy    StrategyCatalogEntry @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, strategyId])
}
